{
    "$schema": "https://schemas.wp.org/trunk/block.json",
    "apiVersion": 3,
    "name": "lfuf/product-card",
    "version": "1.1.0",
    "title": "Product Card",
    "category": "leftfield",
    "icon": "carrot",
    "description": "Display a single Leftfield product with its availability status and source info.",
    "textdomain": "leftfield-farm",
    "attributes": {
        "productId": {
            "type": "number",
            "default": 0
        },
        "showAvailability": {
            "type": "boolean",
            "default": true
        },
        "showSource": {
            "type": "boolean",
            "default": false
        }
    },
    "supports": {
        "html": false,
        "align": ["wide", "full"],
        "color": {
            "background": true,
            "text": true
        },
        "spacing": {
            "margin": true,
            "padding": true
        },
        "__experimentalBorder": {
            "color": true,
            "radius": true,
            "style": true,
            "width": true,
            "__experimentalDefaultControls": {
                "color": true,
                "radius": true,
                "style": true,
                "width": true
            }
        }
    },
    "editorScript": "file:./index.js",
    "render": "file:./render.php",
    "style": "file:./style.css"
}