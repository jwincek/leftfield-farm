{
    "$schema": "https://schemas.wp.org/trunk/block.json",
    "apiVersion": 3,
    "name": "lfuf/location-info",
    "version": "1.0.0",
    "title": "Location Info",
    "category": "leftfield",
    "icon": "store",
    "description": "Display a Leftfield location with open/closed status, hours, address, and Venmo link.",
    "textdomain": "leftfield-core",
    "attributes": {
        "locationId": {
            "type": "number",
            "default": 0
        },
        "showVenmo": {
            "type": "boolean",
            "default": true
        },
        "showStatus": {
            "type": "boolean",
            "default": true
        }
    },
    "supports": {
        "html": false,
        "align": ["wide"],
        "color": {
            "background": true,
            "text": true
        },
        "spacing": {
            "margin": true,
            "padding": true
        }
    },
    "editorScript": "file:./index.js",
    "render": "file:./render.php",
    "style": "file:./style.css"
}
