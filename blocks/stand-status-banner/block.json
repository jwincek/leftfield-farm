{
    "$schema": "https://schemas.wp.org/trunk/block.json",
    "apiVersion": 3,
    "name": "lfuf/stand-status-banner",
    "version": "2.0.0",
    "title": "Stand Status Banner",
    "category": "leftfield",
    "icon": "store",
    "description": "A prominent banner showing the farm stand's current open/closed status, address, hours, Venmo link, and custom status message. Uses the Interactivity API for reactive updates.",
    "textdomain": "leftfield-stand-status",
    "attributes": {
        "locationId": {
            "type": "number",
            "default": 0
        },
        "showAddress": {
            "type": "boolean",
            "default": true
        },
        "showHours": {
            "type": "boolean",
            "default": true
        },
        "showVenmo": {
            "type": "boolean",
            "default": true
        },
        "showSeasonDates": {
            "type": "boolean",
            "default": true
        },
        "layout": {
            "type": "string",
            "default": "banner",
            "enum": ["banner", "compact", "card"]
        },
        "pollingEnabled": {
            "type": "boolean",
            "default": false
        }
    },
    "supports": {
        "html": false,
        "interactivity": true,
        "align": ["wide", "full"],
        "color": {
            "background": true,
            "text": true
        },
        "spacing": {
            "margin": true,
            "padding": true
        }
    },
    "editorScript": "file:./index.js",
    "render": "file:./render.php",
    "style": "file:./style.css",
    "viewScriptModule": "file:./view.js"
}
