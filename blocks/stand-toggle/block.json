{
    "$schema": "https://schemas.wp.org/trunk/block.json",
    "apiVersion": 3,
    "name": "lfuf/stand-toggle",
    "version": "1.0.0",
    "title": "Stand Quick Toggle",
    "category": "leftfield",
    "icon": "controls-repeat",
    "description": "A quick-toggle control panel that renders in the editor for switching stand status. Shows a live toggle + message field. Renders nothing on the front end (admin tool only).",
    "textdomain": "leftfield-stand-status",
    "attributes": {
        "locationId": {
            "type": "number",
            "default": 0
        }
    },
    "supports": {
        "html": false,
        "inserter": true,
        "multiple": false
    },
    "editorScript": "file:./index.js",
    "render": "file:./render.php",
    "editorStyle": "file:./editor.css"
}
